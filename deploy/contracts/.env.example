# Testnet deployer — SAME key we used for feedling (throwaway Sepolia).
# Rotate before any mainnet use. Copy to .env and fill.
PRIVATE_KEY=0x...

# Owner of HivemindAppAuth. Leave unset to use the deployer.
HIVEMIND_APP_AUTH_OWNER=

# Ethereum Sepolia RPC
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Etherscan v2 API key (for verification)
ETHERSCAN_API_KEY=

# Filled in after deploy
HIVEMIND_APP_AUTH_CONTRACT=
